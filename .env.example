# ============================================================
#  Hatef Escape Room — omgevingsvariabelen (voorbeeld)
#  Kopieer dit bestand naar  .env.local  en vul je sleutel in.
#  Zonder sleutel werkt het spel in "offline modus" (lokale beoordeling).
# ============================================================

# --- Optie A: OpenRouter (heeft een GRATIS laag — meestal je "free API") ---
# Maak een sleutel op https://openrouter.ai/keys  (begint met  sk-or-...)
OPENROUTER_API_KEY=

# Welk model. De standaard hieronder is gratis; eventueel aanpasbaar
# (bijv. moonshotai/kimi-k2.6:free).
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# --- Optie B: Claude / Anthropic (gebruikt als OpenRouter leeg is) ---
# Sleutel via https://console.anthropic.com  (begint met  sk-ant-...)
ANTHROPIC_API_KEY=

# --- Optioneel: Supabase (voor toekomstig wereldwijd scorebord) ---
# Het spel werkt volledig zonder deze twee.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
